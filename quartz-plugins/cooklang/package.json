{
  "name": "@danbrazelton/cooklang",
  "version": "1.0.0",
  "description": "Interactive Cooklang recipe renderer for danbrazelton.com",
  "type": "module",
  "license": "MIT",
  "author": "Dan Brazelton",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "peerDependencies": {
    "preact": "^10.0.0"
  },
  "quartz": {
    "name": "cooklang",
    "displayName": "Cooklang Recipes",
    "category": "component",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 50,
    "defaultEnabled": true,
    "defaultOptions": {},
    "components": {
      "Cooklang": {
        "displayName": "Cooklang Recipes",
        "defaultPosition": "afterBody",
        "defaultPriority": 1
      }
    }
  }
}
